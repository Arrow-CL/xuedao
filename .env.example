AI_MODEL=deepseek-chat

# 前端也可读的配置（NEXT_PUBLIC_ 前缀）
NEXT_PUBLIC_AI_ENDPOINT=https://api.deepseek.com/v1/chat/completions
NEXT_PUBLIC_AI_MODEL=deepseek-chat
