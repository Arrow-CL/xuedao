{
  "sets-logic": [
    {
      "name": "交集",
      "latex": "A \\cap B = \\{ x \\mid x \\in A \\mathrm{ 且 } x \\in B \\}"
    },
    {
      "name": "并集",
      "latex": "A \\cup B = \\{ x \\mid x \\in A \\mathrm{ 或 } x \\in B \\}"
    },
    {
      "name": "补集",
      "latex": "\\complement_U A = \\{ x \\mid x \\in U \\mathrm{ 且 } x \\notin A \\}"
    }
  ],
  "quadratic-ineq": [
    {
      "name": "判别式",
      "latex": "\\Delta = b^2 - 4ac"
    },
    {
      "name": "求根公式",
      "latex": "x = \\dfrac{-b \\pm \\sqrt{\\Delta}}{2a}"
    },
    {
      "name": "基本不等式",
      "latex": "a + b \\geq 2\\sqrt{ab}\\;(a,b>0)"
    },
    {
      "name": "韦达定理",
      "latex": "x_1 + x_2 = -\\dfrac{b}{a},\\; x_1x_2 = \\dfrac{c}{a}"
    }
  ],
  "func-concept": [
    {
      "name": "定义域",
      "latex": "f(x)  x "
    },
    {
      "name": "单调性",
      "latex": "x_1 < x_2 \\Rightarrow f(x_1) < f(x_2)"
    },
    {
      "name": "奇偶性",
      "latex": "f(-x) = f(x)\\;(\\mathrm{偶}),\\; f(-x) = -f(x)\\;(\\mathrm{奇})"
    },
    {
      "name": "幂函数",
      "latex": "y = x^\\alpha"
    }
  ],
  "exp-log": [
    {
      "name": "指数运算",
      "latex": "a^m \\cdot a^n = a^{m+n},\\; (a^m)^n = a^{mn}"
    },
    {
      "name": "对数定义",
      "latex": "\\log_a N = b \\iff a^b = N\\;(a>0,a\\neq1)"
    },
    {
      "name": "对数运算",
      "latex": "\\log_a(MN) = \\log_a M + \\log_a N"
    },
    {
      "name": "换底公式",
      "latex": "\\log_a b = \\dfrac{\\log_c b}{\\log_c a}"
    }
  ],
