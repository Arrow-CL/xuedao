      "name": "基本关系",
      "latex": "\\sin^2\\alpha + \\cos^2\\alpha = 1"
    },
    {
      "name": "诱导公式",
      "latex": "\\sin(\\pi-\\alpha)=\\sin\\alpha,\\; \\cos(\\pi-\\alpha)=-\\cos\\alpha"
    },
    {
      "name": "和差公式",
      "latex": "\\sin(\\alpha\\pm\\beta)=\\sin\\alpha\\cos\\beta\\pm\\cos\\alpha\\sin\\beta"
    },
    {
      "name": "二倍角",
      "latex": "\\sin2\\alpha=2\\sin\\alpha\\cos\\alpha,\\; \\cos2\\alpha=2\\cos^2\\alpha-1"
    }
  ],
  "vectors-app": [
