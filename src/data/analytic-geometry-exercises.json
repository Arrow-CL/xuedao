        "answer": "A",
        "gaokaoConnection": "$k=\\dfrac{5-1}{6-2}=1$"
      },
      {
        "id": "ag-le2",
        "unitId": "line-equation",
        "difficulty": 1,
        "type": "choice",
        "prompt": "倾斜角为 $60^{\\circ}$，在 $y$ 轴上截距为 $2$ 的直线方程为（\nA.$y=\\sqrt{3}x+2$  B.$y=\\sqrt{3}x-2$  C.$y=-\\sqrt{3}x+2$  D.$y=\\dfrac{\\sqrt{3}}{3}x+2$）",
        "options": [
          "$y=\\sqrt{3}x+2$",
          "$y=\\sqrt{3}x-2$",
          "$y=-\\sqrt{3}x+2$",
          "$y=\\dfrac{\\sqrt{3}}{3}x+2$"
        ],
        "answer": "A",
        "gaokaoConnection": "$k=\\tan 60^{\\circ}=\\sqrt{3}$，斜截式 $y=\\sqrt{3}x+2$"
      },
      {
        "id": "ag-le3",
        "unitId": "line-equation",
        "difficulty": 2,
        "type": "choice",
        "prompt": "过点 $(1,2)$ 且与直线 $x+2y-1=0$ 平行的直线方程为（\nA.$x+2y-5=0$  B.$x+2y+5=0$  C.$2x+y-5=0$  D.$2x+y+5=0$）",
        "options": [
          "$x+2y-5=0$",
          "$x+2y+5=0$",
          "$2x+y-5=0$",
          "$2x+y+5=0$"
        ],
        "answer": "A",
        "gaokaoConnection": "平行直线系 $x+2y+C=0$，代入 $(1,2)$ 得 $C=-5$"
      },
      {
        "id": "ag-le4",
        "unitId": "line-equation",
        "difficulty": 2,
        "type": "choice",
        "prompt": "点 $(1,0)$ 到直线 $3x+4y-5=0$ 的距离为（\nA.$\\dfrac{1}{5}$  B.$\\dfrac{2}{5}$  C.$1$  D.$2$）",
        "options": [
          "$\\dfrac{1}{5}$",
          "$\\dfrac{2}{5}$",
          "$1$",
          "$2$"
        ],
        "answer": "B",
        "gaokaoConnection": "$d=\\dfrac{|3-5|}{5}=\\dfrac{2}{5}$"
      },
      {
        "id": "ag-le5",
        "unitId": "line-equation",
        "difficulty": 2,
        "type": "choice",
        "prompt": "两条平行直线 $3x+4y-10=0$ 与 $6x+8y+20=0$ 之间的距离为（\nA.$3$  B.$4$  C.$5$  D.$\\dfrac{14}{5}$）",
        "options": [
          "$3$",
          "$4$",
          "$5$",
          "$\\dfrac{14}{5}$"
        ],
        "answer": "B",
        "gaokaoConnection": "化简第二式为 $3x+4y+10=0$，$d=\\dfrac{20}{5}=4$"
      },
      {
        "id": "ag-le6",
        "unitId": "line-equation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "若直线 $l$ 过点 $(2,1)$，且在两坐标轴上的截距相等，则 $l$ 的方程为\\underline{\\hspace{4em}}",
        "options": [],
        "answer": "$x+y-3=0$ 或 $x-2y=0$",
        "gaokaoConnection": "分 $a=b$ 和过原点两种情况讨论"
      },
      {
        "id": "ag-le7",
        "unitId": "line-equation",
        "difficulty": 3,
        "type": "choice",
        "prompt": "已知 $l_1: ax+2y+1=0$ 与 $l_2: x+(a-1)y+3=0$ 互相垂直，则 $a=$（\nA.$\\dfrac{2}{3}$  B.$1$  C.$0$  D.$-1$）",
        "options": [
          "$\\dfrac{2}{3}$",
          "$1$",
          "$0$",
          "$-1$"
        ],
        "answer": "A",
        "gaokaoConnection": "$A_1 A_2+B_1 B_2=0$：$a+2(a-1)=0$，$a=\\dfrac{2}{3}$"
      },
      {
        "id": "ag-le8",
        "unitId": "line-equation",
        "difficulty": 2,
        "type": "choice",
        "prompt": "直线 $x-\\sqrt{3}y+1=0$ 的倾斜角为（\nA.$30^{\\circ}$  B.$60^{\\circ}$  C.$120^{\\circ}$  D.$150^{\\circ}$）",
        "options": [
          "$30^{\\circ}$",
          "$60^{\\circ}$",
          "$120^{\\circ}$",
          "$150^{\\circ}$"
        ],
        "answer": "A",
        "gaokaoConnection": "$k=\\dfrac{1}{\\sqrt{3}}=\\dfrac{\\sqrt{3}}{3}$，$\\alpha=30^{\\circ}$"
      }
    ]
  },
  "circle-equation": {
    "title": "圆的方程",
    "exercises": [
      {
        "id": "ag-ce1",
