{
  "line-equation": {
    "title": "直线方程",
    "exercises": [
      {
        "id": "ag-le1",
        "unitId": "line-equation",
        "difficulty": 1,
        "type": "choice",
        "prompt": "经过点 $A(2,1)$ 和 $B(6,5)$ 的直线斜率为（\nA.$1$  B.$\\dfrac{1}{2}$  C.$2$  D.$-1$）",
