{
  "func-foundation": {
    "title": "函数基础",
    "exercises": [
      {
        "id": "func-f1",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "已知$a>1$且$\\dfrac{1}{\\log_8 a}-\\dfrac{1}{\\log_a 4}=-\\dfrac{5}{2}$，则$a=$____。",
        "answer": "64",
        "gaokaoConnection": "对数换底公式：$\\dfrac{1}{\\log_8 a}=\\log_a 8$，统一底数后求解"
      },
      {
        "id": "func-f2",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=\\begin{cases}\\sqrt{x},&x\\ge0\\\\x+1,&x<0\\end{cases}$，若$f(a)=f(a+1)$，则$f\\left(\\dfrac{1}{a}\\right)=$____",
        "answer": "$4$",
        "gaokaoConnection": "分段函数：分类讨论$a\\ge0$和$a<0$两种情况，利用$f(a)=f(a+1)$列方程"
      },
      {
        "id": "func-f3",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=\\begin{cases}-x^2-2ax-a,&x<0\\\\e^x+\\ln(x+1),&x\\ge0\\end{cases}$在$\\mathbf{R}$单调递增，则$a$范围____",
        "answer": "$[-1,0]$",
        "gaokaoConnection": "分段函数单调递增：各段递增+分段点处左极限$\\le$右极限"
      },
      {
        "id": "func-f4",
        "unitId": "func-foundation",
        "difficulty": 1,
        "type": "fill",
        "prompt": "$a=2^{0.7},b=\\left(\\dfrac{1}{3}\\right)^{0.7},c=\\log_2\\dfrac{1}{3}$，大小____",
        "answer": "$a>b>c$",
        "gaokaoConnection": "指对幂比大小：$a>1,0<b<1,c<0$，先确定正负再比较"
      },
      {
        "id": "func-f5",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$a=\\log_34,b=\\log_{0.7}2,c=5^{-0.1}$，大小____",
        "answer": "$c>b>a$",
        "gaokaoConnection": "$a>1$？$\\log_34<1$；$b=\\log_{0.7}2<0$（底数$<1$真数$>1$）；$c=5^{-0.1}<1$但$>0$"
      },
      {
        "id": "func-f6",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$a=2^{\\frac{4}{7}},b=5^{\\frac{2}{7}},c=25^{\\frac{1}{5}}$，大小____",
        "answer": "$b<a<c$",
        "gaokaoConnection": "$c=25^{1/5}=5^{2/5}$，$a=2^{4/7}$，$b=5^{2/7}$，比较$a^7=16$与$b^7=5^2$？不，$a^{35}=2^{20}$"
      },
      {
        "id": "func-f7",
        "unitId": "func-foundation",
        "difficulty": 2,
        "type": "fill",
        "prompt": "奇函数$f(x)$增函数，$a=-f\\left(\\log_2\\dfrac{1}{5}\\right),b=f(\\log_24.1),c=f(2^{0.8})$，大小____",
        "answer": "$a<b<c$",
        "gaokaoConnection": "奇函数$f(-x)=-f(x)$，$a=-f(-\\log_25)=f(\\log_25)$，比较$\\log_25,\\log_24.1,0.8$"
      }
    ]
  },
  "func-monotonicity": {
    "title": "单调性",
    "exercises": [
      {
        "id": "func-m1",
        "unitId": "func-monotonicity",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=\\dfrac{\\ln2x}{x^2}$递增区间____",
        "answer": "$\\left(0,\\dfrac{1}{8}\\right)$",
        "gaokaoConnection": "求导后令$f'(x)>0$，注意定义域$x>0$"
      },
      {
        "id": "func-m2",
        "unitId": "func-monotonicity",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=2x^3+ax^2-3x-2$在$x=1$取极小值，则极大值为____。",
        "answer": "0",
        "gaokaoConnection": "$f'(1)=0$求$a$，再令$f'(x)=0$找极大值点"
      },
      {
        "id": "func-m3",
        "unitId": "func-monotonicity",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=ae^x-\\ln x$在$(1,2)$递增，$a$最小值____",
        "answer": "$e^{-1}$",
        "gaokaoConnection": "$f'(x)=ae^x-\\dfrac{1}{x}\\ge0$在$(1,2)$恒成立，分离参数求最值"
      }
    ]
  },
  "func-parity": {
    "title": "奇偶性",
    "exercises": [
      {
        "id": "func-p1",
        "unitId": "func-parity",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)$是$\\mathbf{R}$上奇函数，$x>0$时$f(x)=x-1$，若$f(f(x))=1$，则$x=$____。",
        "answer": "3",
        "gaokaoConnection": "奇函数性质：$f(-x)=-f(x)$，$f(0)=0$；分段求$f(f(x))$"
      },
      {
        "id": "func-p2",
        "unitId": "func-parity",
        "difficulty": 2,
        "type": "fill",
        "prompt": "任意$x,f'(x)<g'(x)$，$x\\in(a,b)$时____",
        "answer": "$f(x)+g(a)<g(x)+f(a)$",
        "gaokaoConnection": "$f'(x)<g'(x)\\Rightarrow f(x)-g(x)$递减，利用单调性比较"
      }
    ]
  },
  "func-symmetry-periodicity": {
    "title": "对称性与周期性",
    "exercises": [
      {
        "id": "func-sp1",
        "unitId": "func-symmetry-periodicity",
        "difficulty": 3,
        "type": "fill",
        "prompt": "$f(x)=5\\sin\\dfrac{\\pi}{2}x-|x-1|$所有零点之和____。",
        "answer": "2",
        "gaokaoConnection": "$y=5\\sin\\dfrac{\\pi}{2}x$关于$x=1$对称，$y=|x-1|$也关于$x=1$对称，零点成对出现"
      },
      {
        "id": "func-sp2",
        "unitId": "func-symmetry-periodicity",
        "difficulty": 3,
        "type": "fill",
        "prompt": "奇函数$f(1+x)=f(1-x),x\\in[0,1],f(x)=\\sin\\dfrac{\\pi}{2}x$，$g(x)=f(x)-\\dfrac{1}{|x-4|}$在$[-2,10]$零点之和____。",
        "answer": "16",
        "gaokaoConnection": "由$f(1+x)=f(1-x)$知关于$x=1$对称，结合奇函数得周期为4"
      }
    ]
  },
  "func-transform": {
    "title": "函数图像变换",
    "exercises": [
      {
        "id": "func-t1",
        "unitId": "func-transform",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$y=x\\cos x+\\sin x$在$[-\\pi,\\pi]$的图象大致为____",
        "answer": "A",
        "gaokaoConnection": "判断奇偶性：$f(-x)=-x\\cos(-x)+\\sin(-x)=-x\\cos x-\\sin x=-f(x)$，为奇函数"
      },
      {
        "id": "func-t2",
        "unitId": "func-transform",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$y=\\dfrac{1+x+\\sin x}{x^2}$大致图象为____",
        "answer": "D",
        "gaokaoConnection": "$x\\to+\\infty$时$y\\to0^+$；$x\\to0^+$时分子$\\to1$分母$\\to0^+$，$y\\to+\\infty$"
      },
      {
        "id": "func-t3",
        "unitId": "func-transform",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$y=\\dfrac{-x^2+e^x-e^{-x}}{\\sin x},x\\in[-2.8,2.8]$图象大致为____",
        "answer": "B",
        "gaokaoConnection": "判断奇偶性：分子$-x^2+e^x-e^{-x}$中$e^x-e^{-x}$为奇函数，整体非奇非偶"
      }
    ]
  },
  "func-zeros": {
    "title": "函数零点",
    "exercises": [
      {
        "id": "func-z1",
        "unitId": "func-zeros",
        "difficulty": 1,
        "type": "fill",
        "prompt": "$f(x)=0.3^x-x$零点区间____",
        "answer": "$(0.3,0.5)$",
        "gaokaoConnection": "零点存在定理：$f(0)=1>0,f(0.5)=\\sqrt{0.3}-0.5<0$"
      },
      {
        "id": "func-z2",
        "unitId": "func-zeros",
        "difficulty": 2,
        "type": "fill",
        "prompt": "$f(x)=2^x+3x+a$在$(0,1)$存在零点，$a$范围____",
        "answer": "$(-5,-1)$",
        "gaokaoConnection": "$f(0)=1+a,f(1)=5+a$，零点存在需$f(0)f(1)<0$"
      },
      {
        "id": "func-z3",
        "unitId": "func-zeros",
        "difficulty": 2,
        "type": "fill",
